* { box-sizing: border-box; margin: 0; padding: 0; }
body { background: #06080C; color: #E4E9F1; font-family: 'Segoe UI', -apple-system, sans-serif; }
::-webkit-scrollbar { width: 5px; height: 5px; }
::-webkit-scrollbar-track { background: #0E1218; }
::-webkit-scrollbar-thumb { background: #2E3A4A; border-radius: 3px; }
select option { background: #151B24; color: #E4E9F1; }
@keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
@keyframes slideUp { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
